{
  "name": "antigravity-auto-accept",
  "displayName": "Auto Accept",
  "description": "自动接受 Antigravity Agent 的操作确认（代码编辑、终端命令等）",
  "version": "2.1.0",
  "publisher": "lzl",
  "repository": {
    "type": "git",
    "url": "https://github.com/lzljim/Antigravity-Auto-Accept"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autoAccept.toggle",
        "title": "Auto Accept: Toggle On/Off"
      },
      {
        "command": "autoAccept.showLog",
        "title": "Auto Accept: Show Log"
      },
      {
        "command": "autoAccept.exploreApi",
        "title": "Auto Accept: Explore Antigravity API (Debug)"
      },
      {
        "command": "autoAccept.resetCount",
        "title": "Auto Accept: Reset Count"
      },
      {
        "command": "autoAccept.openDashboard",
        "title": "Auto Accept: Open Dashboard"
      },
      {
        "command": "autoAccept.nightMode.toggle",
        "title": "Auto Accept: Toggle Night Mode 🌙"
      },
      {
        "command": "autoAccept.nightMode.report",
        "title": "Auto Accept: Night Mode Report 🌅"
      },
      {
        "command": "autoAccept.pipeline.toggle",
        "title": "Auto Accept: Toggle Pipeline 🏭"
      },
      {
        "command": "autoAccept.pipeline.addTask",
        "title": "Auto Accept: Add Task to Pipeline ➕"
      },
      {
        "command": "autoAccept.pipeline.decompose",
        "title": "Auto Accept: Decompose Task (AI) 🔬"
      },
      {
        "command": "autoAccept.pipeline.addAndDecompose",
        "title": "Auto Accept: Add & Decompose Task (AI) 🔬➕"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autoAcceptContainer",
          "title": "Auto Accept",
          "icon": "./images/icon.svg"
        }
      ]
    },
    "views": {
      "autoAcceptContainer": [
        {
          "type": "webview",
          "id": "autoAccept.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "keybindings": [
      {
        "command": "autoAccept.toggle",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "Auto Accept",
      "properties": {
        "autoAccept.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用/禁用自动接受"
        },
        "autoAccept.acceptCodeEdits": {
          "type": "boolean",
          "default": true,
          "description": "自动接受代码编辑"
        },
        "autoAccept.acceptTerminalCommands": {
          "type": "boolean",
          "default": true,
          "description": "自动接受终端命令"
        },
        "autoAccept.acceptOtherActions": {
          "type": "boolean",
          "default": true,
          "description": "自动接受其他操作（非代码编辑、非终端命令）"
        },
        "autoAccept.autoRetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "出错时自动切换模型重试"
        },
        "autoAccept.autoRetry.modelFallback": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Claude Opus 4.6 (Thinking)",
            "Claude Sonnet 4.6 (Thinking)",
            "Gemini 3.1 Pro (High)"
          ],
          "description": "模型回退列表（按顺序尝试）"
        },
        "autoAccept.autoRetry.maxRetries": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "最大重试次数"
        },
        "autoAccept.cdpPort": {
          "type": "number",
          "default": 9222,
          "description": "CDP 调试端口，与 IDE 启动参数 --remote-debugging-port 一致"
        },
        "autoAccept.buttonTexts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Run",
            "Allow This Conversation",
            "Always Allow",
            "Allow Once",
            "Accept all",
            "Accept"
          ],
          "description": "自动点击的按钮文本白名单（顺序 = 优先级）"
        },
        "autoAccept.autoRetry.retryButtonTexts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["Retry"],
          "description": "Retry 按钮文本（由 Smart Retry 专门处理）"
        },
        "autoAccept.monitorPollInterval": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "SDK 事件监听轮询间隔（毫秒），作为信号源触发 CDP 扫描"
        },
        "autoAccept.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "silent"
          ],
          "default": "info",
          "description": "日志级别"
        },
        "autoAccept.nightMode.enabled": {
          "type": "boolean",
          "default": false,
          "description": "启用夜间模式（在预设时间内自动激活任务派发）"
        },
        "autoAccept.nightMode.autoActivateHour": {
          "type": "number",
          "default": 23,
          "minimum": 0,
          "maximum": 23,
          "description": "自动激活夜间模式的小时（24h 制）"
        },
        "autoAccept.nightMode.autoDeactivateHour": {
          "type": "number",
          "default": 9,
          "minimum": 0,
          "maximum": 23,
          "description": "自动停止夜间模式的小时（24h 制）"
        },
        "autoAccept.nightMode.maxTaskDurationMinutes": {
          "type": "number",
          "default": 120,
          "minimum": 10,
          "maximum": 480,
          "description": "单个任务最大执行时间（分钟），超时自动跳过"
        },
        "autoAccept.nightMode.nightSafeOnly": {
          "type": "boolean",
          "default": true,
          "description": "夜间模式仅执行带有 night-safe 标签的任务"
        },
        "autoAccept.nightMode.idleThresholdSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 15,
          "maximum": 300,
          "description": "会话空闲检测阈值（秒）"
        },
        "autoAccept.nightMode.quotaWindowHours": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 24,
          "description": "Token 额度刷新窗口时长（小时）"
        },
        "autoAccept.pipeline.enabled": {
          "type": "boolean",
          "default": false,
          "description": "启用流水线调度模式（全天候自动任务派发）"
        },
        "autoAccept.pipeline.workspaces": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "工作空间名称" },
              "branch": { "type": "string", "description": "Git 分支名" },
              "pathPattern": { "type": "string", "description": "路径匹配模式" },
              "sessions": { "type": "number", "default": 2, "description": "该工作空间的会话数" },
              "preferredModels": { "type": "array", "items": { "type": "string" }, "description": "偏好模型列表" }
            },
            "required": ["name"]
          },
          "default": [],
          "description": "工作空间配置列表（每个工作空间对应一个 git 分支）"
        },
        "autoAccept.pipeline.sessionsPerWorkspace": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 5,
          "description": "每个工作空间的默认会话数"
        },
        "autoAccept.pipeline.workspaceIsolation": {
          "type": "string",
          "enum": ["strict", "flexible"],
          "default": "strict",
          "description": "strict: 任务只派发到匹配 workspace 的会话; flexible: 允许跨 workspace 派发"
        },
        "autoAccept.pipeline.taskTimeout": {
          "type": "number",
          "default": 120,
          "minimum": 10,
          "maximum": 480,
          "description": "单任务超时时间（分钟）"
        },
        "autoAccept.pipeline.cooldownBetweenTasks": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "maximum": 60,
          "description": "两次任务派发之间的冷却时间（秒）"
        },
        "autoAccept.pipeline.modelRouting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用智能模型路由（根据任务难度自动选择 Opus/Sonnet/Gemini）"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "node esbuild.js",
    "package": "node esbuild.js --production && npx @vscode/vsce package --no-dependencies --allow-missing-repository",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "antigravity-sdk": "latest",
    "chrome-remote-interface": "^0.33.2",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.23.0"
  }
}
