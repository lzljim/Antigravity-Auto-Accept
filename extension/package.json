{
  "name": "antigravity-auto-accept",
  "displayName": "Auto Accept",
  "description": "自动接受 Antigravity Agent 的操作确认（代码编辑、终端命令等）",
  "version": "1.1.0",
  "publisher": "lzl",
  "repository": {
    "type": "git",
    "url": "https://github.com/lzljim/Antigravity-Auto-Accept"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autoAccept.toggle",
        "title": "Auto Accept: Toggle On/Off"
      },
      {
        "command": "autoAccept.showLog",
        "title": "Auto Accept: Show Log"
      },
      {
        "command": "autoAccept.exploreApi",
        "title": "Auto Accept: Explore Antigravity API (Debug)"
      },
      {
        "command": "autoAccept.resetCount",
        "title": "Auto Accept: Reset Count"
      }
    ],
    "keybindings": [
      {
        "command": "autoAccept.toggle",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "Auto Accept",
      "properties": {
        "autoAccept.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用/禁用自动接受"
        },
        "autoAccept.acceptCodeEdits": {
          "type": "boolean",
          "default": true,
          "description": "自动接受代码编辑"
        },
        "autoAccept.acceptTerminalCommands": {
          "type": "boolean",
          "default": true,
          "description": "自动接受终端命令"
        },
        "autoAccept.acceptOtherActions": {
          "type": "boolean",
          "default": true,
          "description": "自动接受其他操作（非代码编辑、非终端命令）"
        },
        "autoAccept.autoRetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "出错时自动切换模型重试"
        },
        "autoAccept.autoRetry.modelFallback": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Claude Opus 4.6 (Thinking)",
            "Claude Sonnet 4.6 (Thinking)",
            "Gemini 3.1 Pro (High)"
          ],
          "description": "模型回退列表（按顺序尝试）"
        },
        "autoAccept.autoRetry.maxRetries": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "最大重试次数"
        },
        "autoAccept.monitorPollInterval": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "maximum": 30000,
          "description": "事件监听轮询间隔（毫秒）。通常使用事件驱动模式，此参数为降级轮询时的间隔。"
        },
        "autoAccept.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "silent"
          ],
          "default": "info",
          "description": "日志级别"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "node esbuild.js",
    "package": "node esbuild.js --production && npx @vscode/vsce package --no-dependencies --allow-missing-repository",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "antigravity-sdk": "latest"
  }
}
